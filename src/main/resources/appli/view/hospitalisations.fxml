<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.ui.controller.HospitalisationsController"
            prefHeight="650.0" prefWidth="1050.0"
            style="-fx-background-color: #f5f5f5;">

    <!-- BARRE DE NAVIGATION -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #FF9800; -fx-padding: 12 20 12 20;">
            <Button text="&lt; Dashboard" onAction="#goToDashboard"
                    style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 5;"/>
            <Separator orientation="VERTICAL" prefHeight="28" style="-fx-opacity: 0.4;"/>
            <Label text="Salle d'attente — Triage"
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font size="16.0"/></font>
            </Label>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text=""
                   style="-fx-text-fill: white;">
                <font><Font size="12.0"/></font>
            </Label>
            <Label text="|" style="-fx-text-fill: rgba(255,255,255,0.5);"/>
            <Label fx:id="roleLabel" text=""
                   style="-fx-text-fill: white; -fx-background-color: rgba(255,255,255,0.2); -fx-padding: 3 8 3 8; -fx-background-radius: 10;">
                <font><Font size="11.0"/></font>
            </Label>
            <Button text="Deconnexion" onAction="#handleLogout"
                    style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 5;"/>
        </HBox>
    </top>

    <!-- CONTENU CENTRAL -->
    <center>
        <VBox spacing="0">

            <!-- BARRE D'OUTILS -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: white; -fx-padding: 10 15 10 15; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
                <Button text="Rafraichir" onAction="#handleRafraichir"
                        style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Label fx:id="labelCompteurs" text=""
                       style="-fx-text-fill: #666; -fx-font-size: 12;"/>
            </HBox>

            <!-- TABLE DES DOSSIERS OUVERTS -->
            <TableView fx:id="tableDossiers" VBox.vgrow="ALWAYS"
                       maxHeight="Infinity" maxWidth="Infinity">
                <columns>
                    <TableColumn fx:id="colDossier"   text="N° Dossier"    prefWidth="140"/>
                    <TableColumn fx:id="colPatient"   text="Patient"        prefWidth="180"/>
                    <TableColumn fx:id="colArrivee"   text="Arrivee"        prefWidth="130"/>
                    <TableColumn fx:id="colAttente"   text="Attente"        prefWidth="90"/>
                    <TableColumn fx:id="colGravite"   text="Gravite"        prefWidth="120"/>
                    <TableColumn fx:id="colMode"      text="Mode"           prefWidth="100"/>
                    <TableColumn fx:id="colStatut"    text="Statut"         prefWidth="100"/>
                    <TableColumn fx:id="colSymptomes" text="Symptomes"      prefWidth="200"/>
                </columns>
                <placeholder>
                    <Label text="Aucun dossier ouvert en ce moment"
                           style="-fx-text-fill: #aaaaaa; -fx-font-size: 13;"/>
                </placeholder>
            </TableView>

            <!-- BOUTONS D'ACTION -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: white; -fx-padding: 10 15 10 15; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">
                <Button fx:id="btnPrendreEnCharge" text="Prendre en charge"
                        onAction="#handlePrendreEnCharge"
                        disable="true"
                        style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
                <Button fx:id="btnVoirDossier" text="Voir le dossier"
                        onAction="#handleVoirDossier"
                        disable="true"
                        style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Label fx:id="labelStatus" text=""
                       style="-fx-text-fill: #555; -fx-font-size: 11;"/>
            </HBox>

        </VBox>
    </center>

    <!-- BARRE DE STATUT -->
    <bottom>
        <HBox alignment="CENTER"
              style="-fx-background-color: #eeeeee; -fx-padding: 7 15 7 15;">
            <Label text="HSP - Salle d'attente / Triage"
                   style="-fx-text-fill: #999; -fx-font-size: 11;"/>
        </HBox>
    </bottom>

</BorderPane>
