<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.ui.controller.JournalController"
            prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #FFF9E7;">

    <stylesheets>
        <URL value="@cartoon.css"/>
    </stylesheets>

    <!-- ===== EN-TETE ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: #2D3436;
                     -fx-padding: 14 25 14 25;
                     -fx-border-color: #1a1a1a;
                     -fx-border-width: 0 0 4 0;
                     -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.45), 0, 0, 0, 5);">
            <Button text="Dashboard" onAction="#goToDashboard"
                    style="-fx-background-color: rgba(255,255,255,0.9);
                           -fx-text-fill: #1a1a1a;
                           -fx-font-weight: bold;
                           -fx-border-color: #1a1a1a;
                           -fx-border-width: 2;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 2, 2);"/>
            <Separator orientation="VERTICAL" prefHeight="28" style="-fx-opacity: 0.4;"/>
            <Label text="Journal des Actions"
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font name="System Bold" size="16.0"/></font>
            </Label>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text=""
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font size="13.0"/></font>
            </Label>
            <Label fx:id="roleLabel" text=""
                   style="-fx-text-fill: #1a1a1a;
                          -fx-background-color: rgba(255,255,255,0.9);
                          -fx-padding: 4 12 4 12;
                          -fx-background-radius: 14;
                          -fx-border-color: #1a1a1a;
                          -fx-border-width: 2;
                          -fx-border-radius: 14;
                          -fx-font-weight: bold;">
                <font><Font size="12.0"/></font>
            </Label>
            <Button text="Deconnexion" onAction="#handleLogout"
                    style="-fx-background-color: #FF7675;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-border-color: #1a1a1a;
                           -fx-border-width: 2;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 2, 2);"/>
        </HBox>
    </top>

    <!-- ===== CONTENU ===== -->
    <center>
        <VBox spacing="15">
            <padding><Insets top="20" right="25" bottom="20" left="25"/></padding>

            <!-- Barre de filtres -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: white;
                         -fx-padding: 12 16 12 16;
                         -fx-background-radius: 12;
                         -fx-border-color: #1a1a1a;
                         -fx-border-width: 2.5;
                         -fx-border-radius: 12;
                         -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 3, 3);">
                <Label text="Filtres :"
                       style="-fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                <Label text="Du" style="-fx-font-weight: bold;"/>
                <DatePicker fx:id="dateDebut" prefWidth="140"/>
                <Label text="au" style="-fx-font-weight: bold;"/>
                <DatePicker fx:id="dateFin" prefWidth="140"/>
                <Label text="Type" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="filterType" prefWidth="160"/>
                <Label text="Utilisateur" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="filterUser" prefWidth="180"/>
                <Button text="Filtrer" onAction="#handleFilter"
                        style="-fx-background-color: #2D3436;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                <Button text="Reinitialiser" onAction="#handleResetFilters"
                        style="-fx-background-color: #DFE6E9;
                               -fx-text-fill: #1a1a1a;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 3, 3);"/>
            </HBox>

            <!-- Tableau journal -->
            <TableView fx:id="journalTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="150"/>
                    <TableColumn fx:id="colUser" text="Utilisateur" prefWidth="150"/>
                    <TableColumn fx:id="colType" text="Type" prefWidth="120"/>
                    <TableColumn fx:id="colDescription" text="Description" prefWidth="300"/>
                    <TableColumn fx:id="colEntite" text="Entite" prefWidth="100"/>
                    <TableColumn fx:id="colIP" text="Adresse IP" prefWidth="120"/>
                </columns>
                <placeholder><Label text="Aucune entree dans le journal"/></placeholder>
            </TableView>

            <HBox alignment="CENTER_RIGHT">
                <Label fx:id="statusLabel" text="0 entree(s)"
                       style="-fx-text-fill: #636E72; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
