<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.ui.controller.UtilisateursController"
            prefHeight="700.0" prefWidth="1000.0"
            style="-fx-background-color: #FFF9E7;">

    <stylesheets>
        <URL value="@cartoon.css"/>
    </stylesheets>

    <!-- ===== EN-TETE ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: #D63031;
                     -fx-padding: 14 25 14 25;
                     -fx-border-color: #1a1a1a;
                     -fx-border-width: 0 0 4 0;
                     -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.45), 0, 0, 0, 5);">
            <Button text="Dashboard" onAction="#goToDashboard"
                    style="-fx-background-color: rgba(255,255,255,0.9);
                           -fx-text-fill: #1a1a1a;
                           -fx-font-weight: bold;
                           -fx-border-color: #1a1a1a;
                           -fx-border-width: 2;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 2, 2);"/>
            <Separator orientation="VERTICAL" prefHeight="28" style="-fx-opacity: 0.4;"/>
            <Label text="Gestion des Utilisateurs"
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font name="System Bold" size="16.0"/></font>
            </Label>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text=""
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font size="13.0"/></font>
            </Label>
            <Label fx:id="roleLabel" text=""
                   style="-fx-text-fill: #1a1a1a;
                          -fx-background-color: rgba(255,255,255,0.9);
                          -fx-padding: 4 12 4 12;
                          -fx-background-radius: 14;
                          -fx-border-color: #1a1a1a;
                          -fx-border-width: 2;
                          -fx-border-radius: 14;
                          -fx-font-weight: bold;">
                <font><Font size="12.0"/></font>
            </Label>
            <Button text="Deconnexion" onAction="#handleLogout"
                    style="-fx-background-color: #2D3436;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-border-color: #1a1a1a;
                           -fx-border-width: 2;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 2, 2);"/>
        </HBox>
    </top>

    <!-- ===== CONTENU ===== -->
    <center>
        <VBox spacing="15">
            <padding><Insets top="20" right="25" bottom="20" left="25"/></padding>

            <!-- Barre d'actions -->
            <HBox spacing="10">
                <Button fx:id="btnAjouter" text="+ Ajouter" onAction="#handleAddUser"
                        style="-fx-background-color: #55EFC4;
                               -fx-text-fill: #1a1a1a;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                <Button fx:id="btnModifier" text="Modifier" onAction="#handleEditUser" disable="true"
                        style="-fx-background-color: #FDCB6E;
                               -fx-text-fill: #1a1a1a;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                <Button fx:id="btnToggleActif" text="Desactiver" onAction="#handleToggleActif" disable="true"
                        style="-fx-background-color: #FF7675;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
            </HBox>

            <!-- Tableau utilisateurs -->
            <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="130"/>
                    <TableColumn fx:id="colPrenom" text="Prenom" prefWidth="130"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
                    <TableColumn fx:id="colRole" text="Role" prefWidth="130"/>
                    <TableColumn fx:id="colActif" text="Actif" prefWidth="60"/>
                    <TableColumn fx:id="colDerniereConnexion" text="Derniere connexion" prefWidth="150"/>
                </columns>
                <placeholder><Label text="Aucun utilisateur"/></placeholder>
            </TableView>

            <HBox alignment="CENTER_RIGHT">
                <Label fx:id="statusLabel" text="0 utilisateur(s)"
                       style="-fx-text-fill: #636E72; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </center>

    <!-- Bas de page -->
    <bottom>
        <HBox alignment="CENTER"
              style="-fx-background-color: #FFEAA7;
                     -fx-padding: 8;
                     -fx-border-color: #1a1a1a;
                     -fx-border-width: 3 0 0 0;">
            <Label text="Administration des comptes utilisateurs"
                   style="-fx-text-fill: #636E72; -fx-font-weight: bold;">
                <font><Font size="11.0"/></font>
            </Label>
        </HBox>
    </bottom>

</BorderPane>
