<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.ui.controller.OrdonnancesController"
            prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #FFF9E7;">

    <stylesheets>
        <URL value="@cartoon.css"/>
    </stylesheets>

    <!-- EN-TETE -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #6C5CE7;
                     -fx-padding: 12 20 12 20;
                     -fx-border-color: #1a1a1a;
                     -fx-border-width: 0 0 4 0;
                     -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.45), 0, 0, 0, 5);">
            <Button text="&lt; Retour" onAction="#handleRetour"
                    style="-fx-background-color: rgba(255,255,255,0.2);
                           -fx-text-fill: white; -fx-font-weight: bold;
                           -fx-border-color: rgba(255,255,255,0.5); -fx-border-width: 2;
                           -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Label text="Ordonnances" style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font size="18.0"/></font>
            </Label>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text="Bienvenue"
                   style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <Label text="|" style="-fx-text-fill: rgba(255,255,255,0.4);"/>
            <Label fx:id="roleLabel" text="Role"
                   style="-fx-text-fill: #1a1a1a;
                          -fx-background-color: rgba(255,255,255,0.9);
                          -fx-padding: 4 10 4 10; -fx-background-radius: 12;
                          -fx-border-color: #1a1a1a; -fx-border-width: 2;
                          -fx-border-radius: 12; -fx-font-weight: bold;"/>
            <Button text="Deconnexion" onAction="#handleLogout"
                    style="-fx-background-color: #FF7675; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-border-color: #1a1a1a; -fx-border-width: 2;
                           -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- CONTENU -->
    <center>
        <VBox spacing="14">
            <padding><Insets top="18" right="24" bottom="18" left="24"/></padding>

            <!-- Barre de filtres -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: white;
                         -fx-padding: 12;
                         -fx-border-color: #1a1a1a; -fx-border-width: 3;
                         -fx-border-radius: 12; -fx-background-radius: 12;">
                <Label text="Statut :" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cbFiltreStatut" prefWidth="160"/>
            </HBox>

            <!-- Tableau ordonnances -->
            <TableView fx:id="tableOrdonnances" VBox.vgrow="ALWAYS"
                       style="-fx-border-color: #1a1a1a; -fx-border-width: 3; -fx-border-radius: 10;">
                <columns>
                    <TableColumn fx:id="colNumero" text="N° Ordonnance" prefWidth="160"/>
                    <TableColumn fx:id="colDate" text="Date prescription" prefWidth="160"/>
                    <TableColumn fx:id="colStatut" text="Statut" prefWidth="110"/>
                    <TableColumn fx:id="colDossier" text="Dossier" prefWidth="100"/>
                    <TableColumn fx:id="colDateFin" text="Date fin" prefWidth="110"/>
                    <TableColumn fx:id="colNotes" text="Notes" prefWidth="200"/>
                </columns>
                <placeholder>
                    <Label text="Aucune ordonnance trouvee." style="-fx-font-weight: bold;"/>
                </placeholder>
            </TableView>

            <!-- Detail lignes (visible sur selection) -->
            <VBox fx:id="sectionLignes" visible="false" managed="false" spacing="8"
                  style="-fx-background-color: white;
                         -fx-border-color: #6C5CE7; -fx-border-width: 3;
                         -fx-border-radius: 12; -fx-background-radius: 12;">
                <padding><Insets top="12" right="14" bottom="12" left="14"/></padding>
                <Label fx:id="lblTitreDetail" text="Lignes de prescription"
                       style="-fx-font-weight: bold; -fx-text-fill: #6C5CE7;">
                    <font><Font size="14.0"/></font>
                </Label>
                <TableView fx:id="tableLignes" prefHeight="180"
                           style="-fx-border-color: #DDD; -fx-border-width: 2;">
                    <columns>
                        <TableColumn fx:id="colProduit" text="Medicament" prefWidth="200"/>
                        <TableColumn fx:id="colPosologie" text="Posologie" prefWidth="160"/>
                        <TableColumn fx:id="colQuantite" text="Qte" prefWidth="60"/>
                        <TableColumn fx:id="colVoie" text="Voie" prefWidth="120"/>
                        <TableColumn fx:id="colDuree" text="Duree" prefWidth="80"/>
                        <TableColumn fx:id="colInstructions" text="Instructions" prefWidth="220"/>
                    </columns>
                    <placeholder>
                        <Label text="Aucune ligne." style="-fx-font-style: italic;"/>
                    </placeholder>
                </TableView>
            </VBox>
        </VBox>
    </center>

    <!-- PIED DE PAGE -->
    <bottom>
        <HBox alignment="CENTER"
              style="-fx-background-color: #FFEAA7; -fx-padding: 8;
                     -fx-border-color: #1a1a1a; -fx-border-width: 3 0 0 0;">
            <Label text="HSP - Ordonnances"
                   style="-fx-text-fill: #636E72; -fx-font-weight: bold;">
                <font><Font size="11.0"/></font>
            </Label>
        </HBox>
    </bottom>

</BorderPane>
