<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.ui.controller.RendezVousController"
            prefHeight="720.0" prefWidth="1200.0"
            style="-fx-background-color: #FFF9E7;">

    <stylesheets>
        <URL value="@cartoon.css"/>
    </stylesheets>

    <!-- ===== EN-TETE ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: #FD79A8;
                     -fx-padding: 14 25 14 25;
                     -fx-border-color: #1a1a1a;
                     -fx-border-width: 0 0 4 0;
                     -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.45), 0, 0, 0, 5);">
            <Button text="Dashboard" onAction="#goToDashboard"
                    style="-fx-background-color: rgba(255,255,255,0.9);
                           -fx-text-fill: #1a1a1a;
                           -fx-font-weight: bold;
                           -fx-border-color: #1a1a1a;
                           -fx-border-width: 2;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 2, 2);"/>
            <Separator orientation="VERTICAL" prefHeight="28" style="-fx-opacity: 0.4;"/>
            <Label text="Rendez-vous"
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font name="System Bold" size="16.0"/></font>
            </Label>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text=""
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font size="13.0"/></font>
            </Label>
            <Label fx:id="roleLabel" text=""
                   style="-fx-text-fill: #1a1a1a;
                          -fx-background-color: rgba(255,255,255,0.9);
                          -fx-padding: 4 12 4 12;
                          -fx-background-radius: 14;
                          -fx-border-color: #1a1a1a;
                          -fx-border-width: 2;
                          -fx-border-radius: 14;
                          -fx-font-weight: bold;">
                <font><Font size="12.0"/></font>
            </Label>
            <Button text="Actualiser" onAction="#handleRefresh"
                    style="-fx-background-color: rgba(255,255,255,0.85);
                           -fx-text-fill: #1a1a1a;
                           -fx-font-weight: bold;
                           -fx-border-color: #1a1a1a;
                           -fx-border-width: 2;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.4), 0, 0, 2, 2);"/>
            <Button text="Deconnexion" onAction="#handleLogout"
                    style="-fx-background-color: #FF7675;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-border-color: #1a1a1a;
                           -fx-border-width: 2;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 2, 2);"/>
        </HBox>
    </top>

    <!-- ===== CONTENU ===== -->
    <center>
        <VBox spacing="12">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

            <!-- Barre de recherche et filtres -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <TextField fx:id="searchField"
                           promptText="Rechercher patient, medecin ou n° RDV..."
                           prefWidth="280" prefHeight="34"
                           onAction="#handleSearch"/>
                <Button text="Rechercher" onAction="#handleSearch"
                        style="-fx-background-color: #74B9FF;
                               -fx-text-fill: #1a1a1a;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                <Label text="Statut :" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cbFiltreStatut" prefWidth="130" onAction="#handleFiltreChange"/>
                <ToggleButton fx:id="tglAVenir" text="A venir uniquement"
                              onAction="#handleToggleAVenir"
                              style="-fx-font-weight: bold;
                                     -fx-border-color: #1a1a1a;
                                     -fx-border-width: 2;
                                     -fx-border-radius: 8;
                                     -fx-background-radius: 8;
                                     -fx-cursor: hand;"/>
            </HBox>

            <!-- Barre d'actions -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button fx:id="btnNouveauRdv" text="+ Nouveau RDV" onAction="#handleNouveauRdv"
                        style="-fx-background-color: #55EFC4;
                               -fx-text-fill: #1a1a1a;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                <Button fx:id="btnModifier" text="Modifier" onAction="#handleModifier" disable="true"
                        style="-fx-background-color: #FDCB6E;
                               -fx-text-fill: #1a1a1a;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                <Button fx:id="btnConfirmer" text="Confirmer" onAction="#handleConfirmer" disable="true"
                        style="-fx-background-color: #74B9FF;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                <Button fx:id="btnRealise" text="Marquer Realise" onAction="#handleRealise" disable="true"
                        style="-fx-background-color: #A29BFE;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                <Button fx:id="btnReporter" text="Reporter" onAction="#handleReporter" disable="true"
                        style="-fx-background-color: #FFEAA7;
                               -fx-text-fill: #1a1a1a;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                <Button fx:id="btnAnnuler" text="Annuler RDV" onAction="#handleAnnuler" disable="true"
                        style="-fx-background-color: #E17055;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                <Button fx:id="btnSupprimer" text="Supprimer" onAction="#handleSupprimer" disable="true"
                        style="-fx-background-color: #FF7675;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
            </HBox>

            <!-- Legende couleurs -->
            <HBox spacing="20" alignment="CENTER_LEFT"
                  style="-fx-padding: 6 10 6 10;
                         -fx-background-color: rgba(255,255,255,0.7);
                         -fx-background-radius: 8;
                         -fx-border-color: #dfe6e9;
                         -fx-border-width: 1.5;
                         -fx-border-radius: 8;">
                <Label text="Legende :" style="-fx-font-weight: bold; -fx-font-size: 11;"/>
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label prefWidth="14" prefHeight="14"
                           style="-fx-background-color: #d4efdf; -fx-background-radius: 3; -fx-border-color: #ccc; -fx-border-width: 1;"/>
                    <Label text="Confirme" style="-fx-font-size: 11;"/>
                </HBox>
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label prefWidth="14" prefHeight="14"
                           style="-fx-background-color: #d6eaf8; -fx-background-radius: 3; -fx-border-color: #ccc; -fx-border-width: 1;"/>
                    <Label text="Realise" style="-fx-font-size: 11;"/>
                </HBox>
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label prefWidth="14" prefHeight="14"
                           style="-fx-background-color: #fadbd8; -fx-background-radius: 3; -fx-border-color: #ccc; -fx-border-width: 1;"/>
                    <Label text="Annule" style="-fx-font-size: 11;"/>
                </HBox>
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label prefWidth="14" prefHeight="14"
                           style="-fx-background-color: #fdebd0; -fx-background-radius: 3; -fx-border-color: #ccc; -fx-border-width: 1;"/>
                    <Label text="Reporte" style="-fx-font-size: 11;"/>
                </HBox>
            </HBox>

            <!-- Tableau -->
            <TableView fx:id="rdvTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNumero"  text="N° RDV"      prefWidth="140"/>
                    <TableColumn fx:id="colPatient" text="Patient"      prefWidth="160"/>
                    <TableColumn fx:id="colMedecin" text="Medecin"      prefWidth="160"/>
                    <TableColumn fx:id="colDate"    text="Date / Heure" prefWidth="140"/>
                    <TableColumn fx:id="colDuree"   text="Duree"        prefWidth="75"/>
                    <TableColumn fx:id="colType"    text="Type"         prefWidth="110"/>
                    <TableColumn fx:id="colStatut"  text="Statut"       prefWidth="95"/>
                    <TableColumn fx:id="colMotif"   text="Motif"        prefWidth="200"/>
                    <TableColumn fx:id="colLieu"    text="Lieu"         prefWidth="120"/>
                </columns>
                <placeholder><Label text="Aucun rendez-vous"/></placeholder>
            </TableView>

            <!-- Barre de statut -->
            <HBox alignment="CENTER_RIGHT">
                <Label fx:id="statusLabel" text="0 rendez-vous"
                       style="-fx-text-fill: #636E72; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
