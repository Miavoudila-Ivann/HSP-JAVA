<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.ui.controller.DemandesController"
            prefHeight="650.0" prefWidth="1050.0"
            style="-fx-background-color: #f5f5f5;">

    <!-- BARRE DE NAVIGATION -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #9C27B0; -fx-padding: 12 20 12 20;">
            <Button text="&lt; Dashboard" onAction="#goToDashboard"
                    style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 5;"/>
            <Separator orientation="VERTICAL" prefHeight="28" style="-fx-opacity: 0.4;"/>
            <Label text="Demandes de Produits"
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font size="16.0"/></font>
            </Label>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text=""
                   style="-fx-text-fill: white;">
                <font><Font size="12.0"/></font>
            </Label>
            <Label text="|" style="-fx-text-fill: rgba(255,255,255,0.5);"/>
            <Label fx:id="roleLabel" text=""
                   style="-fx-text-fill: white; -fx-background-color: rgba(255,255,255,0.2); -fx-padding: 3 8 3 8; -fx-background-radius: 10;">
                <font><Font size="11.0"/></font>
            </Label>
            <Button text="Deconnexion" onAction="#handleLogout"
                    style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 5;"/>
        </HBox>
    </top>

    <!-- CONTENU CENTRAL -->
    <center>
        <HBox spacing="0">

            <!-- PANNEAU GAUCHE : NOUVELLE DEMANDE -->
            <VBox spacing="14" prefWidth="360" minWidth="320"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #e0e0e0; -fx-border-width: 0 1 0 0;">

                <Label text="Nouvelle demande"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #9C27B0;"/>
                <Separator/>

                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="100"/>
                        <ColumnConstraints hgrow="ALWAYS" fillWidth="true"/>
                    </columnConstraints>

                    <Label text="Produit *" GridPane.rowIndex="0" GridPane.columnIndex="0"
                           style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                    <ComboBox fx:id="cbProduit" GridPane.rowIndex="0" GridPane.columnIndex="1"
                              maxWidth="Infinity"
                              promptText="Choisir un produit..."/>

                    <Label text="Quantite *" GridPane.rowIndex="1" GridPane.columnIndex="0"
                           style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                    <TextField fx:id="tfQuantite" GridPane.rowIndex="1" GridPane.columnIndex="1"
                               maxWidth="120" promptText="Ex : 10" text="1"/>

                    <Label text="Urgence" GridPane.rowIndex="2" GridPane.columnIndex="0"
                           style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                    <CheckBox fx:id="cbUrgence" GridPane.rowIndex="2" GridPane.columnIndex="1"
                              text="Marquer comme urgent"/>

                    <Label text="Date besoin" GridPane.rowIndex="3" GridPane.columnIndex="0"
                           style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                    <DatePicker fx:id="dpDateBesoin" GridPane.rowIndex="3" GridPane.columnIndex="1"
                                maxWidth="Infinity"/>

                    <Label text="Motif *" GridPane.rowIndex="4" GridPane.columnIndex="0"
                           style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                    <TextArea fx:id="taMotif" GridPane.rowIndex="4" GridPane.columnIndex="1"
                              prefRowCount="3" wrapText="true" maxWidth="Infinity"
                              promptText="Justification de la demande..."/>
                </GridPane>

                <Label fx:id="labelErreur" text=""
                       style="-fx-text-fill: #F44336; -fx-font-size: 11;" wrapText="true"/>
                <Label fx:id="labelConfirmation" text=""
                       style="-fx-text-fill: #388E3C; -fx-font-size: 11;" wrapText="true"/>

                <Button text="Envoyer la demande" onAction="#handleEnvoyerDemande"
                        style="-fx-background-color: #9C27B0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-size: 13;" prefHeight="38"/>

            </VBox>

            <!-- PANNEAU DROIT : HISTORIQUE -->
            <VBox spacing="0" HBox.hgrow="ALWAYS">

                <!-- Toolbar historique -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: #f9f9f9; -fx-padding: 10 15 10 15; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
                    <Label text="Mes demandes"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                    <HBox HBox.hgrow="ALWAYS"/>
                    <Button text="Rafraichir" onAction="#handleRafraichirHistorique"
                            style="-fx-background-color: #e0e0e0; -fx-text-fill: #333; -fx-background-radius: 5; -fx-cursor: hand;"/>
                </HBox>

                <TableView fx:id="tableHistorique" VBox.vgrow="ALWAYS"
                           maxHeight="Infinity" maxWidth="Infinity">
                    <columns>
                        <TableColumn fx:id="colNumeroDemande" text="N° Demande"    prefWidth="150"/>
                        <TableColumn fx:id="colProduit"       text="Produit"        prefWidth="160"/>
                        <TableColumn fx:id="colQuantite"      text="Qte"            prefWidth="55"/>
                        <TableColumn fx:id="colUrgence"       text="Urgence"        prefWidth="70"/>
                        <TableColumn fx:id="colDateDemande"   text="Date demande"   prefWidth="120"/>
                        <TableColumn fx:id="colDateBesoin"    text="Date besoin"    prefWidth="100"/>
                        <TableColumn fx:id="colStatutDemande" text="Statut"         prefWidth="110"/>
                    </columns>
                    <placeholder>
                        <Label text="Aucune demande enregistree"
                               style="-fx-text-fill: #aaa;"/>
                    </placeholder>
                </TableView>

            </VBox>

        </HBox>
    </center>

    <!-- BARRE DE STATUT -->
    <bottom>
        <HBox alignment="CENTER"
              style="-fx-background-color: #eeeeee; -fx-padding: 7 15 7 15;">
            <Label text="HSP - Demandes de Produits"
                   style="-fx-text-fill: #999; -fx-font-size: 11;"/>
        </HBox>
    </bottom>

</BorderPane>
