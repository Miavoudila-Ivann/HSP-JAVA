<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.ui.controller.DemandesController"
            prefHeight="800.0" prefWidth="1200.0"
            style="-fx-background-color: #FFF9E7;">

    <stylesheets>
        <URL value="@cartoon.css"/>
    </stylesheets>

    <!-- ===== EN-TETE ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: #6C5CE7;
                     -fx-padding: 14 25 14 25;
                     -fx-border-color: #1a1a1a;
                     -fx-border-width: 0 0 4 0;
                     -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.45), 0, 0, 0, 5);">
            <Button text="Dashboard" onAction="#goToDashboard"
                    style="-fx-background-color: rgba(255,255,255,0.9);
                           -fx-text-fill: #1a1a1a;
                           -fx-font-weight: bold;
                           -fx-border-color: #1a1a1a;
                           -fx-border-width: 2;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 2, 2);"/>
            <Separator orientation="VERTICAL" prefHeight="28" style="-fx-opacity: 0.4;"/>
            <Label text="Demandes de Produits"
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font name="System Bold" size="16.0"/></font>
            </Label>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text=""
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font size="13.0"/></font>
            </Label>
            <Label fx:id="roleLabel" text=""
                   style="-fx-text-fill: #1a1a1a;
                          -fx-background-color: rgba(255,255,255,0.9);
                          -fx-padding: 4 12 4 12;
                          -fx-background-radius: 14;
                          -fx-border-color: #1a1a1a;
                          -fx-border-width: 2;
                          -fx-border-radius: 14;
                          -fx-font-weight: bold;">
                <font><Font size="12.0"/></font>
            </Label>
            <Button text="Actualiser" onAction="#handleRefresh"
                    style="-fx-background-color: rgba(255,255,255,0.85);
                           -fx-text-fill: #1a1a1a;
                           -fx-font-weight: bold;
                           -fx-border-color: #1a1a1a;
                           -fx-border-width: 2;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.4), 0, 0, 2, 2);"/>
            <Button text="Deconnexion" onAction="#handleLogout"
                    style="-fx-background-color: #FF7675;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-border-color: #1a1a1a;
                           -fx-border-width: 2;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 2, 2);"/>
        </HBox>
    </top>

    <!-- ===== CONTENU ===== -->
    <center>
        <VBox spacing="12">
            <padding><Insets top="18" right="25" bottom="18" left="25"/></padding>

            <!-- Section Medecin -->
            <VBox fx:id="medecinSection" spacing="10">
                <Label text="Mes demandes"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #6C5CE7;
                              -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.12), 0, 0, 1, 1);"/>
                <HBox spacing="10">
                    <Button text="+ Nouvelle demande" onAction="#handleNewDemand"
                            style="-fx-background-color: #A29BFE;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-border-color: #1a1a1a;
                                   -fx-border-width: 2.5;
                                   -fx-border-radius: 8;
                                   -fx-background-radius: 8;
                                   -fx-cursor: hand;
                                   -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                </HBox>
                <TableView fx:id="mesDemandesTable" prefHeight="220" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colMesNum" text="N. Demande" prefWidth="140"/>
                        <TableColumn fx:id="colMesProduit" text="Produit" prefWidth="160"/>
                        <TableColumn fx:id="colMesQte" text="Quantite" prefWidth="110"/>
                        <TableColumn fx:id="colMesUrgence" text="Urgence" prefWidth="70"/>
                        <TableColumn fx:id="colMesStatut" text="Statut" prefWidth="100"/>
                        <TableColumn fx:id="colMesDate" text="Date" prefWidth="130"/>
                        <TableColumn fx:id="colMesCommentaire" text="Commentaire" prefWidth="200"/>
                    </columns>
                    <placeholder><Label text="Aucune demande"/></placeholder>
                </TableView>
            </VBox>

            <Separator/>

            <!-- Section Gestionnaire -->
            <VBox fx:id="gestionnaireSection" spacing="10">
                <Label text="Demandes en attente de validation"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #6C5CE7;
                              -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.12), 0, 0, 1, 1);"/>
                <HBox spacing="10">
                    <Button fx:id="btnValider" text="Valider"
                            onAction="#handleValidate" disable="true"
                            style="-fx-background-color: #55EFC4;
                                   -fx-text-fill: #1a1a1a;
                                   -fx-font-weight: bold;
                                   -fx-border-color: #1a1a1a;
                                   -fx-border-width: 2.5;
                                   -fx-border-radius: 8;
                                   -fx-background-radius: 8;
                                   -fx-cursor: hand;
                                   -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                    <Button fx:id="btnRefuser" text="Refuser"
                            onAction="#handleRefuse" disable="true"
                            style="-fx-background-color: #FF7675;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-border-color: #1a1a1a;
                                   -fx-border-width: 2.5;
                                   -fx-border-radius: 8;
                                   -fx-background-radius: 8;
                                   -fx-cursor: hand;
                                   -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                </HBox>
                <TableView fx:id="attenteDemandesTable" prefHeight="220" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colAttNum" text="N. Demande" prefWidth="140"/>
                        <TableColumn fx:id="colAttProduit" text="Produit" prefWidth="160"/>
                        <TableColumn fx:id="colAttQte" text="Quantite" prefWidth="80"/>
                        <TableColumn fx:id="colAttMedecin" text="Medecin" prefWidth="140"/>
                        <TableColumn fx:id="colAttUrgence" text="Urgence" prefWidth="80"/>
                        <TableColumn fx:id="colAttMotif" text="Motif" prefWidth="180"/>
                        <TableColumn fx:id="colAttDate" text="Date" prefWidth="130"/>
                    </columns>
                    <placeholder><Label text="Aucune demande en attente"/></placeholder>
                </TableView>
            </VBox>

            <HBox alignment="CENTER_RIGHT">
                <Label fx:id="statusLabel" text=""
                       style="-fx-text-fill: #636E72; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
