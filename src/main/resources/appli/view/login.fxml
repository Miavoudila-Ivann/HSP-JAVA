<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.ui.controller.LoginController"
            prefHeight="480.0" prefWidth="540.0"
            style="-fx-background-color: #FFF9E7;">

    <stylesheets>
        <URL value="@cartoon.css"/>
    </stylesheets>

    <center>
        <!-- Carte cartoon centrale -->
        <VBox alignment="CENTER" spacing="18.0"
              style="-fx-background-color: white;
                     -fx-background-radius: 20;
                     -fx-border-color: #1a1a1a;
                     -fx-border-width: 4;
                     -fx-border-radius: 20;
                     -fx-effect: dropshadow(three_pass_box, #1a1a1a, 0, 0, 7, 7);"
              maxWidth="380" maxHeight="420">
            <padding>
                <Insets bottom="40.0" left="45.0" right="45.0" top="10.0"/>
            </padding>

            <!-- Bandeau titre cartoon -->
            <VBox alignment="CENTER" spacing="4"
                  style="-fx-background-color: #6C5CE7;
                         -fx-background-radius: 16 16 0 0;
                         -fx-border-color: #1a1a1a;
                         -fx-border-width: 0 0 3 0;
                         -fx-padding: 20 0 16 0;">
                <Label text="HSP"
                       style="-fx-text-fill: white; -fx-font-weight: bold; -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.4), 0, 0, 2, 2);">
                    <font><Font name="System Bold" size="36.0"/></font>
                </Label>
                <Label text="Gestion Hospitaliere"
                       style="-fx-text-fill: #DDD8F8; -fx-font-weight: bold;">
                    <font><Font size="12.0"/></font>
                </Label>
            </VBox>

            <!-- Champ email -->
            <VBox spacing="5.0">
                <Label text="Email" style="-fx-text-fill: #1a1a1a; -fx-font-weight: bold;">
                    <font><Font size="13.0"/></font>
                </Label>
                <TextField fx:id="emailField" promptText="votre@email.fr"
                           prefWidth="290" prefHeight="38"
                           onKeyPressed="#handleKeyPressed"/>
            </VBox>

            <!-- Champ mot de passe -->
            <VBox spacing="5.0">
                <Label text="Mot de passe" style="-fx-text-fill: #1a1a1a; -fx-font-weight: bold;">
                    <font><Font size="13.0"/></font>
                </Label>
                <PasswordField fx:id="passwordField" promptText="••••••••"
                               prefWidth="290" prefHeight="38"
                               onKeyPressed="#handleKeyPressed"/>
            </VBox>

            <!-- Message d'erreur -->
            <Label fx:id="errorLabel" text=""
                   style="-fx-text-fill: white;
                          -fx-background-color: #FF7675;
                          -fx-background-radius: 8;
                          -fx-border-color: #1a1a1a;
                          -fx-border-width: 2;
                          -fx-border-radius: 8;
                          -fx-padding: 6 12 6 12;
                          -fx-font-weight: bold;"
                   visible="false" managed="false">
                <font><Font size="12.0"/></font>
            </Label>

            <!-- Bouton connexion -->
            <Button text="Se connecter" onAction="#handleLogin"
                    prefWidth="290" prefHeight="44"
                    style="-fx-background-color: #E17055;
                           -fx-text-fill: white;
                           -fx-font-size: 15;
                           -fx-font-weight: bold;
                           -fx-background-radius: 12;
                           -fx-border-color: #1a1a1a;
                           -fx-border-width: 3;
                           -fx-border-radius: 12;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(three_pass_box, #1a1a1a, 0, 0, 4, 4);">
            </Button>


        </VBox>
    </center>

    <!-- Bas de page -->
    <bottom>
        <VBox alignment="CENTER" style="-fx-padding: 10;">
            <Label text="v1.0 - Systeme de Gestion Hospitaliere"
                   style="-fx-text-fill: #B2BEC3; -fx-font-style: italic;">
                <font><Font size="11.0"/></font>
            </Label>
        </VBox>
    </bottom>

</BorderPane>
