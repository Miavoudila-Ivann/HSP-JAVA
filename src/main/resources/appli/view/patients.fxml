<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.ui.controller.PatientsController"
            prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #FFF9E7;">

    <stylesheets>
        <URL value="@cartoon.css"/>
    </stylesheets>

    <!-- ===== EN-TETE ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: #0984E3;
                     -fx-padding: 14 25 14 25;
                     -fx-border-color: #1a1a1a;
                     -fx-border-width: 0 0 4 0;
                     -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.45), 0, 0, 0, 5);">
            <Button text="Dashboard" onAction="#goToDashboard"
                    style="-fx-background-color: rgba(255,255,255,0.9);
                           -fx-text-fill: #1a1a1a;
                           -fx-font-weight: bold;
                           -fx-border-color: #1a1a1a;
                           -fx-border-width: 2;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 2, 2);"/>
            <Separator orientation="VERTICAL" prefHeight="28" style="-fx-opacity: 0.4;"/>
            <Label text="Gestion des Patients"
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font name="System Bold" size="16.0"/></font>
            </Label>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text=""
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font size="13.0"/></font>
            </Label>
            <Label fx:id="roleLabel" text=""
                   style="-fx-text-fill: #1a1a1a;
                          -fx-background-color: rgba(255,255,255,0.9);
                          -fx-padding: 4 12 4 12;
                          -fx-background-radius: 14;
                          -fx-border-color: #1a1a1a;
                          -fx-border-width: 2;
                          -fx-border-radius: 14;
                          -fx-font-weight: bold;">
                <font><Font size="12.0"/></font>
            </Label>
            <Button text="Deconnexion" onAction="#handleLogout"
                    style="-fx-background-color: #FF7675;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-border-color: #1a1a1a;
                           -fx-border-width: 2;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 2, 2);"/>
        </HBox>
    </top>

    <!-- ===== CONTENU ===== -->
    <center>
        <VBox spacing="14">
            <padding><Insets top="20" right="25" bottom="20" left="25"/></padding>

            <!-- Barre d'actions -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <TextField fx:id="searchField"
                           promptText="Rechercher par nom, prenom ou SSN..."
                           prefWidth="300" prefHeight="36"/>
                <Button text="Rechercher" onAction="#handleSearch"
                        style="-fx-background-color: #74B9FF;
                               -fx-text-fill: #1a1a1a;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                <Button text="Actualiser" onAction="#handleRefresh"
                        style="-fx-background-color: #DFE6E9;
                               -fx-text-fill: #1a1a1a;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 3, 3);"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnAjouter" text="+ Ajouter patient" onAction="#handleAddPatient"
                        style="-fx-background-color: #55EFC4;
                               -fx-text-fill: #1a1a1a;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                <Button fx:id="btnModifier" text="Modifier" onAction="#handleEditPatient" disable="true"
                        style="-fx-background-color: #FDCB6E;
                               -fx-text-fill: #1a1a1a;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                <Button fx:id="btnDossier" text="Creer dossier" onAction="#handleCreateDossier" disable="true"
                        style="-fx-background-color: #A29BFE;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                <Button fx:id="btnSupprimer" text="Supprimer" onAction="#handleDeletePatient" disable="true"
                        style="-fx-background-color: #FF7675;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                <Button fx:id="btnExportPDF" text="Export PDF" onAction="#handleExportPatient" disable="true"
                        style="-fx-background-color: #E17055;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 2.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
            </HBox>

            <!-- Tableau patients -->
            <TableView fx:id="patientTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="130"/>
                    <TableColumn fx:id="colPrenom" text="Prenom" prefWidth="130"/>
                    <TableColumn fx:id="colSSN" text="N. Secu. Sociale" prefWidth="160"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                    <TableColumn fx:id="colTelephone" text="Telephone" prefWidth="130"/>
                    <TableColumn fx:id="colDateNaissance" text="Date naissance" prefWidth="120"/>
                </columns>
                <placeholder><Label text="Aucun patient"/></placeholder>
            </TableView>

            <!-- Barre de statut -->
            <HBox alignment="CENTER_RIGHT">
                <Label fx:id="statusLabel" text="0 patient(s)"
                       style="-fx-text-fill: #636E72; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
