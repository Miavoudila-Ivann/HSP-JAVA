<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.ui.controller.DashboardController"
            prefHeight="600.0" prefWidth="900.0"
            style="-fx-background-color: #f5f5f5;">

    <!-- Barre du haut : info utilisateur + deconnexion -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: #2196F3; -fx-padding: 15 25 15 25;">
            <Label text="HSP" style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font size="20.0"/></font>
            </Label>
            <Separator orientation="VERTICAL" prefHeight="30" style="-fx-opacity: 0.3;"/>
            <Label text="Tableau de bord" style="-fx-text-fill: white;">
                <font><Font size="16.0"/></font>
            </Label>
            <!-- Spacer -->
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text="Bienvenue" style="-fx-text-fill: white;">
                <font><Font size="13.0"/></font>
            </Label>
            <Label text="|" style="-fx-text-fill: rgba(255,255,255,0.5);"/>
            <Label fx:id="roleLabel" text="Role"
                   style="-fx-text-fill: white; -fx-background-color: rgba(255,255,255,0.2); -fx-padding: 4 10 4 10; -fx-background-radius: 12;">
                <font><Font size="12.0"/></font>
            </Label>
            <Button text="Deconnexion" onAction="#handleLogout"
                    style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 5;">
            </Button>
        </HBox>
    </top>

    <!-- Contenu central : grille adaptative de navigation -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="30">
            <padding>
                <Insets top="40" right="50" bottom="40" left="50"/>
            </padding>

            <Label text="Menu Principal" style="-fx-text-fill: #333333;">
                <font><Font name="System Bold" size="22.0"/></font>
            </Label>

            <Label text="Selectionnez un module pour commencer" style="-fx-text-fill: #888888;">
                <font><Font size="13.0"/></font>
            </Label>

            <!--
                FlowPane : les boutons s'arrangent automatiquement selon ceux qui sont visibles.
                Chaque role verra uniquement ses modules autorises, centres a l'ecran.
            -->
            <FlowPane alignment="CENTER" hgap="20" vgap="20">

                <!-- Patients : SECRETAIRE, MEDECIN, ADMIN -->
                <Button fx:id="btnPatients" onAction="#goToPatients"
                        prefWidth="200" prefHeight="110"
                        style="-fx-background-color: white; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2); -fx-border-color: #e0e0e0; -fx-border-radius: 10;">
                    <graphic>
                        <VBox alignment="CENTER" spacing="6">
                            <Label text="Patients"
                                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
                            <Label text="Dossiers &amp; admissions"
                                   style="-fx-font-size: 10; -fx-text-fill: #888888;"/>
                        </VBox>
                    </graphic>
                </Button>

                <!-- Hospitalisations : MEDECIN, ADMIN -->
                <Button fx:id="btnHospitalisations" onAction="#goToHospitalisations"
                        prefWidth="200" prefHeight="110"
                        style="-fx-background-color: white; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2); -fx-border-color: #e0e0e0; -fx-border-radius: 10;">
                    <graphic>
                        <VBox alignment="CENTER" spacing="6">
                            <Label text="Hospitalisations"
                                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                            <Label text="Chambres &amp; sejours"
                                   style="-fx-font-size: 10; -fx-text-fill: #888888;"/>
                        </VBox>
                    </graphic>
                </Button>

                <!-- Stock : GESTIONNAIRE, ADMIN -->
                <Button fx:id="btnStock" onAction="#goToStock"
                        prefWidth="200" prefHeight="110"
                        style="-fx-background-color: white; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2); -fx-border-color: #e0e0e0; -fx-border-radius: 10;">
                    <graphic>
                        <VBox alignment="CENTER" spacing="6">
                            <Label text="Stock"
                                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                            <Label text="Produits &amp; inventaire"
                                   style="-fx-font-size: 10; -fx-text-fill: #888888;"/>
                        </VBox>
                    </graphic>
                </Button>

                <!-- Demandes : MEDECIN, GESTIONNAIRE, ADMIN -->
                <Button fx:id="btnDemandes" onAction="#goToDemandes"
                        prefWidth="200" prefHeight="110"
                        style="-fx-background-color: white; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2); -fx-border-color: #e0e0e0; -fx-border-radius: 10;">
                    <graphic>
                        <VBox alignment="CENTER" spacing="6">
                            <Label text="Demandes"
                                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #9C27B0;"/>
                            <Label text="Produits &amp; validation"
                                   style="-fx-font-size: 10; -fx-text-fill: #888888;"/>
                        </VBox>
                    </graphic>
                </Button>

                <!-- Utilisateurs : ADMIN uniquement -->
                <Button fx:id="btnUtilisateurs" onAction="#goToUtilisateurs"
                        prefWidth="200" prefHeight="110"
                        style="-fx-background-color: white; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2); -fx-border-color: #e0e0e0; -fx-border-radius: 10;">
                    <graphic>
                        <VBox alignment="CENTER" spacing="6">
                            <Label text="Utilisateurs"
                                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #F44336;"/>
                            <Label text="Comptes &amp; acces"
                                   style="-fx-font-size: 10; -fx-text-fill: #888888;"/>
                        </VBox>
                    </graphic>
                </Button>

                <!-- Journal : ADMIN uniquement -->
                <Button fx:id="btnJournal" onAction="#goToJournal"
                        prefWidth="200" prefHeight="110"
                        style="-fx-background-color: white; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2); -fx-border-color: #e0e0e0; -fx-border-radius: 10;">
                    <graphic>
                        <VBox alignment="CENTER" spacing="6">
                            <Label text="Journal"
                                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #607D8B;"/>
                            <Label text="Historique des actions"
                                   style="-fx-font-size: 10; -fx-text-fill: #888888;"/>
                        </VBox>
                    </graphic>
                </Button>

            </FlowPane>

        </VBox>
    </center>

    <!-- Barre du bas -->
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #eeeeee; -fx-padding: 10;">
            <Label text="HSP - Systeme de Gestion Hospitaliere" style="-fx-text-fill: #999999;">
                <font><Font size="11.0"/></font>
            </Label>
        </HBox>
    </bottom>

</BorderPane>
