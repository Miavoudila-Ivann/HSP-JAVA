<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.ui.controller.NewTriageCaseController"
            prefHeight="680.0" prefWidth="800.0"
            style="-fx-background-color: #f5f5f5;">

    <!-- BARRE DE NAVIGATION -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #FF9800; -fx-padding: 12 20 12 20;">
            <Button text="&lt; Patients" onAction="#handleRetour"
                    style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 5;"/>
            <Separator orientation="VERTICAL" prefHeight="28" style="-fx-opacity: 0.4;"/>
            <Label text="Nouveau Cas de Triage"
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font size="16.0"/></font>
            </Label>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text=""
                   style="-fx-text-fill: white;">
                <font><Font size="12.0"/></font>
            </Label>
            <Label text="|" style="-fx-text-fill: rgba(255,255,255,0.5);"/>
            <Label fx:id="roleLabel" text=""
                   style="-fx-text-fill: white; -fx-background-color: rgba(255,255,255,0.2); -fx-padding: 3 8 3 8; -fx-background-radius: 10;">
                <font><Font size="11.0"/></font>
            </Label>
            <Button text="Deconnexion" onAction="#handleLogout"
                    style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 5;"/>
        </HBox>
    </top>

    <!-- CONTENU PRINCIPAL -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: #f5f5f5;">
            <VBox spacing="16" style="-fx-padding: 30 60 40 60; -fx-background-color: #f5f5f5;">

                <!-- TITRE -->
                <Label text="Enregistrement d'un cas de triage"
                       style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                <Separator/>

                <!-- SECTION 1 : PATIENT -->
                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2); -fx-border-color: #e0e0e0; -fx-border-radius: 8;">

                    <Label text="1. Patient"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                    <Separator/>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="tfSearchPatient"
                                   promptText="Rechercher par nom ou NSS..."
                                   prefWidth="360"
                                   onAction="#handleRecherchePatient"/>
                        <Button text="Chercher" onAction="#handleRecherchePatient"
                                style="-fx-background-color: #607D8B; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    </HBox>

                    <!-- Liste des resultats de recherche (cachee par defaut) -->
                    <ListView fx:id="lvPatients"
                              prefHeight="130"
                              visible="false" managed="false"
                              style="-fx-border-color: #e0e0e0; -fx-border-radius: 4;"/>

                    <!-- Patient selectionne -->
                    <HBox spacing="8" alignment="CENTER_LEFT"
                          style="-fx-background-color: #E8F5E9; -fx-padding: 10; -fx-background-radius: 6;"
                          fx:id="boxPatientSelectionne" visible="false" managed="false">
                        <Label text="Patient :" style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                        <Label fx:id="labelPatientSelectionne" text=""
                               style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
                    </HBox>

                </VBox>

                <!-- SECTION 2 : ARRIVEE -->
                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2); -fx-border-color: #e0e0e0; -fx-border-radius: 8;">

                    <Label text="2. Arrivee"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                    <Separator/>

                    <GridPane hgap="16" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="140" prefWidth="140"/>
                            <ColumnConstraints hgrow="ALWAYS" fillWidth="true"/>
                        </columnConstraints>
                        <Label text="Mode d'arrivee :" GridPane.rowIndex="0" GridPane.columnIndex="0"
                               style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                        <ComboBox fx:id="cbModeArrivee" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                  maxWidth="300"/>
                    </GridPane>

                </VBox>

                <!-- SECTION 3 : MOTIF ET SYMPTOMES -->
                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2); -fx-border-color: #e0e0e0; -fx-border-radius: 8;">

                    <Label text="3. Motif et symptomes"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                    <Separator/>

                    <GridPane hgap="16" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="140" prefWidth="140"/>
                            <ColumnConstraints hgrow="ALWAYS" fillWidth="true"/>
                        </columnConstraints>

                        <Label text="Motif d'admission :" GridPane.rowIndex="0" GridPane.columnIndex="0"
                               style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                        <TextField fx:id="tfMotif" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                   maxWidth="Infinity" promptText="Raison de la venue aux urgences"/>

                        <Label text="Symptomes * :" GridPane.rowIndex="1" GridPane.columnIndex="0"
                               style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                        <TextArea fx:id="taSymptomes" GridPane.rowIndex="1" GridPane.columnIndex="1"
                                  prefRowCount="4" maxWidth="Infinity" wrapText="true"
                                  promptText="Decrire les symptomes observes..."/>
                    </GridPane>

                </VBox>

                <!-- SECTION 4 : NIVEAU DE GRAVITE -->
                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2); -fx-border-color: #e0e0e0; -fx-border-radius: 8;">

                    <Label text="4. Niveau de gravite *"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                    <Separator/>

                    <Label text="Selectionner le niveau selon l'etat clinique observe :"
                           style="-fx-font-size: 11; -fx-text-fill: #888;"/>

                    <!-- Boutons de niveau de gravite codes par couleur -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button fx:id="btnNiveau5" text="5 — Critique"
                                onAction="#handleSelectNiveau5"
                                prefWidth="140" prefHeight="50"
                                style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 12;"/>
                        <Button fx:id="btnNiveau4" text="4 — Grave"
                                onAction="#handleSelectNiveau4"
                                prefWidth="140" prefHeight="50"
                                style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 12;"/>
                        <Button fx:id="btnNiveau3" text="3 — Serieux"
                                onAction="#handleSelectNiveau3"
                                prefWidth="140" prefHeight="50"
                                style="-fx-background-color: #FFC107; -fx-text-fill: #333; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 12;"/>
                        <Button fx:id="btnNiveau2" text="2 — Modere"
                                onAction="#handleSelectNiveau2"
                                prefWidth="140" prefHeight="50"
                                style="-fx-background-color: #8BC34A; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 12;"/>
                        <Button fx:id="btnNiveau1" text="1 — Mineur"
                                onAction="#handleSelectNiveau1"
                                prefWidth="140" prefHeight="50"
                                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 12;"/>
                    </HBox>

                    <Label fx:id="labelNiveauSelectionne" text="Aucun niveau selectionne"
                           style="-fx-font-size: 12; -fx-text-fill: #888; -fx-font-style: italic;"/>

                </VBox>

                <!-- MESSAGE D'ERREUR -->
                <Label fx:id="labelErreur" text=""
                       style="-fx-text-fill: #F44336; -fx-font-size: 12;"
                       wrapText="true"/>

                <!-- ACTIONS -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Button text="Enregistrer le dossier" onAction="#handleEnregistrer"
                            prefHeight="40"
                            style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Button text="Annuler" onAction="#handleRetour"
                            prefHeight="40"
                            style="-fx-background-color: #e0e0e0; -fx-text-fill: #333; -fx-font-size: 13; -fx-background-radius: 6; -fx-cursor: hand;"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- BARRE DE STATUT -->
    <bottom>
        <HBox alignment="CENTER"
              style="-fx-background-color: #eeeeee; -fx-padding: 7 15 7 15; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">
            <Label text="HSP - Triage aux Urgences"
                   style="-fx-text-fill: #999999; -fx-font-size: 11;"/>
        </HBox>
    </bottom>

</BorderPane>
