<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.ui.controller.StockController"
            prefHeight="800.0" prefWidth="1200.0"
            style="-fx-background-color: #FFF9E7;">

    <stylesheets>
        <URL value="@cartoon.css"/>
    </stylesheets>

    <!-- ===== EN-TETE ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: #00B894;
                     -fx-padding: 14 25 14 25;
                     -fx-border-color: #1a1a1a;
                     -fx-border-width: 0 0 4 0;
                     -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.45), 0, 0, 0, 5);">
            <Button text="Dashboard" onAction="#goToDashboard"
                    style="-fx-background-color: rgba(255,255,255,0.9);
                           -fx-text-fill: #1a1a1a;
                           -fx-font-weight: bold;
                           -fx-border-color: #1a1a1a;
                           -fx-border-width: 2;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 2, 2);"/>
            <Separator orientation="VERTICAL" prefHeight="28" style="-fx-opacity: 0.4;"/>
            <Label text="Gestion du Stock"
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font name="System Bold" size="16.0"/></font>
            </Label>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text=""
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font size="13.0"/></font>
            </Label>
            <Label fx:id="roleLabel" text=""
                   style="-fx-text-fill: #1a1a1a;
                          -fx-background-color: rgba(255,255,255,0.9);
                          -fx-padding: 4 12 4 12;
                          -fx-background-radius: 14;
                          -fx-border-color: #1a1a1a;
                          -fx-border-width: 2;
                          -fx-border-radius: 14;
                          -fx-font-weight: bold;">
                <font><Font size="12.0"/></font>
            </Label>
            <Button text="Deconnexion" onAction="#handleLogout"
                    style="-fx-background-color: #FF7675;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-border-color: #1a1a1a;
                           -fx-border-width: 2;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 2, 2);"/>
        </HBox>
    </top>

    <!-- ===== CONTENU : ONGLETS ===== -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <padding><Insets top="12" right="15" bottom="12" left="15"/></padding>

            <!-- ====== ONGLET PRODUITS ====== -->
            <Tab text="Produits">
                <VBox spacing="10">
                    <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="searchProduitField" promptText="Rechercher un produit (nom, code...)"
                                   prefWidth="300" onAction="#handleSearchProduit"
                                   style="-fx-border-color: #1a1a1a;
                                          -fx-border-width: 2;
                                          -fx-border-radius: 8;
                                          -fx-background-radius: 8;"/>
                        <Button text="Rechercher" onAction="#handleSearchProduit"
                                style="-fx-background-color: #74B9FF;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-border-color: #1a1a1a;
                                       -fx-border-width: 2.5;
                                       -fx-border-radius: 8;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;
                                       -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                        <Button text="Reinitialiser" onAction="#handleRefreshProduit"
                                style="-fx-background-color: rgba(255,255,255,0.9);
                                       -fx-text-fill: #1a1a1a;
                                       -fx-font-weight: bold;
                                       -fx-border-color: #1a1a1a;
                                       -fx-border-width: 2.5;
                                       -fx-border-radius: 8;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;
                                       -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                        <HBox HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnAddProduit" text="+ Ajouter produit"
                                onAction="#handleAddProduit"
                                style="-fx-background-color: #55EFC4;
                                       -fx-text-fill: #1a1a1a;
                                       -fx-font-weight: bold;
                                       -fx-border-color: #1a1a1a;
                                       -fx-border-width: 2.5;
                                       -fx-border-radius: 8;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;
                                       -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                        <Button fx:id="btnEditProduit" text="Modifier"
                                onAction="#handleEditProduit" disable="true"
                                style="-fx-background-color: #FDCB6E;
                                       -fx-text-fill: #1a1a1a;
                                       -fx-font-weight: bold;
                                       -fx-border-color: #1a1a1a;
                                       -fx-border-width: 2.5;
                                       -fx-border-radius: 8;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;
                                       -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                    </HBox>
                    <TableView fx:id="produitTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colProdCode" text="Code" prefWidth="100"/>
                            <TableColumn fx:id="colProdNom" text="Nom" prefWidth="220"/>
                            <TableColumn fx:id="colProdForme" text="Forme" prefWidth="120"/>
                            <TableColumn fx:id="colProdDangerosite" text="Dangerosite" prefWidth="120"/>
                            <TableColumn fx:id="colProdStock" text="Stock" prefWidth="80"/>
                            <TableColumn fx:id="colProdSeuil" text="Seuil alerte" prefWidth="90"/>
                        </columns>
                        <placeholder><Label text="Aucun produit"/></placeholder>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ====== ONGLET FOURNISSEURS ====== -->
            <Tab text="Fournisseurs">
                <VBox spacing="10">
                    <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                    <HBox spacing="10">
                        <Button fx:id="btnAddFournisseur" text="+ Ajouter fournisseur"
                                onAction="#handleAddFournisseur"
                                style="-fx-background-color: #55EFC4;
                                       -fx-text-fill: #1a1a1a;
                                       -fx-font-weight: bold;
                                       -fx-border-color: #1a1a1a;
                                       -fx-border-width: 2.5;
                                       -fx-border-radius: 8;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;
                                       -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                        <Button fx:id="btnEditFournisseur" text="Modifier"
                                onAction="#handleEditFournisseur" disable="true"
                                style="-fx-background-color: #FDCB6E;
                                       -fx-text-fill: #1a1a1a;
                                       -fx-font-weight: bold;
                                       -fx-border-color: #1a1a1a;
                                       -fx-border-width: 2.5;
                                       -fx-border-radius: 8;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;
                                       -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                    </HBox>
                    <TableView fx:id="fournisseurTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colFournCode" text="Code" prefWidth="100"/>
                            <TableColumn fx:id="colFournNom" text="Nom" prefWidth="200"/>
                            <TableColumn fx:id="colFournEmail" text="Email" prefWidth="200"/>
                            <TableColumn fx:id="colFournTel" text="Telephone" prefWidth="130"/>
                            <TableColumn fx:id="colFournVille" text="Ville" prefWidth="130"/>
                        </columns>
                        <placeholder><Label text="Aucun fournisseur"/></placeholder>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ====== ONGLET REAPPROVISIONNEMENT ====== -->
            <Tab text="Reapprovisionnement">
                <VBox spacing="15">
                    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                    <Label text="Nouveau reapprovisionnement"
                           style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #00B894;
                                  -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.12), 0, 0, 1, 1);"/>

                    <GridPane hgap="12" vgap="10">
                        <Label text="Produit* :" GridPane.columnIndex="0" GridPane.rowIndex="0"
                               style="-fx-font-weight: bold;"/>
                        <ComboBox fx:id="reapProduitCombo" prefWidth="300"
                                  GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Fournisseur :" GridPane.columnIndex="0" GridPane.rowIndex="1"
                               style="-fx-font-weight: bold;"/>
                        <ComboBox fx:id="reapFournisseurCombo" prefWidth="300"
                                  GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Quantite* :" GridPane.columnIndex="0" GridPane.rowIndex="2"
                               style="-fx-font-weight: bold;"/>
                        <TextField fx:id="reapQuantiteField" promptText="Quantite" prefWidth="150"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="N. Lot* :" GridPane.columnIndex="0" GridPane.rowIndex="3"
                               style="-fx-font-weight: bold;"/>
                        <TextField fx:id="reapLotField" promptText="Numero de lot" prefWidth="200"
                                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <Label text="Date peremption :" GridPane.columnIndex="0" GridPane.rowIndex="4"
                               style="-fx-font-weight: bold;"/>
                        <DatePicker fx:id="reapDatePeremption" prefWidth="200"
                                    GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                        <Label text="Prix unitaire :" GridPane.columnIndex="0" GridPane.rowIndex="5"
                               style="-fx-font-weight: bold;"/>
                        <TextField fx:id="reapPrixField" promptText="0.00" prefWidth="150"
                                   GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                        <Label text="N. Commande :" GridPane.columnIndex="0" GridPane.rowIndex="6"
                               style="-fx-font-weight: bold;"/>
                        <TextField fx:id="reapCommandeField" promptText="Reference commande" prefWidth="200"
                                   GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                    </GridPane>

                    <Button text="Reapprovisionner" onAction="#handleReapprovisionner"
                            style="-fx-background-color: #00B894;
                                   -fx-text-fill: white;
                                   -fx-font-size: 14;
                                   -fx-font-weight: bold;
                                   -fx-border-color: #1a1a1a;
                                   -fx-border-width: 2.5;
                                   -fx-border-radius: 10;
                                   -fx-background-radius: 10;
                                   -fx-cursor: hand;
                                   -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 4, 4);"/>

                    <Separator/>

                    <Label text="Derniers mouvements de stock"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                    <TableView fx:id="mouvementTable" prefHeight="200" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colMvtDate" text="Date" prefWidth="140"/>
                            <TableColumn fx:id="colMvtType" text="Type" prefWidth="100"/>
                            <TableColumn fx:id="colMvtQuantite" text="Quantite" prefWidth="80"/>
                            <TableColumn fx:id="colMvtMotif" text="Motif" prefWidth="200"/>
                            <TableColumn fx:id="colMvtRef" text="Reference" prefWidth="150"/>
                        </columns>
                        <placeholder><Label text="Aucun mouvement"/></placeholder>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ====== ONGLET ALERTES ====== -->
            <Tab text="Alertes">
                <VBox spacing="12">
                    <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

                    <!-- Barre du haut -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button fx:id="btnActualiserAlertes" text="Actualiser les alertes"
                                onAction="#handleActualiserAlertes"
                                style="-fx-background-color: #00B894;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-border-color: #1a1a1a;
                                       -fx-border-width: 2.5;
                                       -fx-border-radius: 8;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;
                                       -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                        <Button fx:id="btnToutMarquerLu" text="Tout marquer comme lu"
                                onAction="#handleToutMarquerLu"
                                style="-fx-background-color: #74B9FF;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-border-color: #1a1a1a;
                                       -fx-border-width: 2.5;
                                       -fx-border-radius: 8;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;
                                       -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.7), 0, 0, 3, 3);"/>
                    </HBox>

                    <!-- Cartes KPI -->
                    <HBox spacing="15" alignment="CENTER">
                        <!-- Critiques -->
                        <VBox alignment="CENTER" prefWidth="200" prefHeight="80"
                              style="-fx-background-color: #FF7675;
                                     -fx-background-radius: 14;
                                     -fx-border-color: #1a1a1a;
                                     -fx-border-width: 3;
                                     -fx-border-radius: 14;
                                     -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 4, 4);">
                            <Label fx:id="lblCritiques" text="0"
                                   style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 28;"/>
                            <Label text="Critiques"
                                   style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;"/>
                        </VBox>
                        <!-- Avertissements -->
                        <VBox alignment="CENTER" prefWidth="200" prefHeight="80"
                              style="-fx-background-color: #FDCB6E;
                                     -fx-background-radius: 14;
                                     -fx-border-color: #1a1a1a;
                                     -fx-border-width: 3;
                                     -fx-border-radius: 14;
                                     -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 4, 4);">
                            <Label fx:id="lblWarnings" text="0"
                                   style="-fx-text-fill: #1a1a1a; -fx-font-weight: bold; -fx-font-size: 28;"/>
                            <Label text="Avertissements"
                                   style="-fx-text-fill: #1a1a1a; -fx-font-weight: bold; -fx-font-size: 13;"/>
                        </VBox>
                        <!-- Informations -->
                        <VBox alignment="CENTER" prefWidth="200" prefHeight="80"
                              style="-fx-background-color: #74B9FF;
                                     -fx-background-radius: 14;
                                     -fx-border-color: #1a1a1a;
                                     -fx-border-width: 3;
                                     -fx-border-radius: 14;
                                     -fx-effect: dropshadow(three_pass_box, rgba(0,0,0,0.5), 0, 0, 4, 4);">
                            <Label fx:id="lblInfos" text="0"
                                   style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 28;"/>
                            <Label text="Informations"
                                   style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;"/>
                        </VBox>
                    </HBox>

                    <!-- Tableau des alertes -->
                    <TableView fx:id="alerteTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colAlNiveau" text="Niveau" prefWidth="100"/>
                            <TableColumn fx:id="colAlType" text="Type" prefWidth="130"/>
                            <TableColumn fx:id="colAlTitre" text="Titre" prefWidth="200"/>
                            <TableColumn fx:id="colAlMessage" text="Message" prefWidth="300"/>
                            <TableColumn fx:id="colAlDate" text="Date" prefWidth="140"/>
                            <TableColumn fx:id="colAlActions" text="Actions" prefWidth="100"/>
                        </columns>
                        <placeholder><Label text="Aucune alerte active"/></placeholder>
                    </TableView>
                </VBox>
            </Tab>
        </TabPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT"
              style="-fx-padding: 6 25 10 25;
                     -fx-background-color: #FFEAA7;
                     -fx-border-color: #1a1a1a;
                     -fx-border-width: 3 0 0 0;">
            <Label fx:id="statusLabel" text=""
                   style="-fx-text-fill: #636E72; -fx-font-weight: bold;"/>
        </HBox>
    </bottom>

</BorderPane>
