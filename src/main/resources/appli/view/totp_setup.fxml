<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.ui.controller.TotpSetupController"
            prefHeight="620.0" prefWidth="580.0"
            style="-fx-background-color: #FFF9E7;">

    <stylesheets>
        <URL value="@cartoon.css"/>
    </stylesheets>

    <!-- En-tete -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: #6C5CE7;
                     -fx-padding: 14 25 14 25;
                     -fx-border-color: #1a1a1a;
                     -fx-border-width: 0 0 4 0;">
            <Label text="HSP" style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font size="22.0"/></font>
            </Label>
            <Label text="|" style="-fx-text-fill: rgba(255,255,255,0.4);"/>
            <Label text="Configuration 2FA"
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font size="16.0"/></font>
            </Label>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="Retour" onAction="#handleBack"
                    style="-fx-background-color: rgba(255,255,255,0.2);
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-border-color: white;
                           -fx-border-width: 2;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;">
            </Button>
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="20"
              style="-fx-padding: 30 50 30 50;">

            <!-- Titre -->
            <Label text="Authentification a deux facteurs (2FA)"
                   style="-fx-text-fill: #1a1a1a; -fx-font-weight: bold;">
                <font><Font name="System Bold" size="18.0"/></font>
            </Label>

            <!-- Section activation -->
            <VBox alignment="CENTER" spacing="14"
                  style="-fx-background-color: white;
                         -fx-background-radius: 16;
                         -fx-border-color: #1a1a1a;
                         -fx-border-width: 3;
                         -fx-border-radius: 16;
                         -fx-padding: 20;
                         -fx-effect: dropshadow(three_pass_box, #1a1a1a, 0, 0, 4, 4);">

                <!-- QR Code -->
                <ImageView fx:id="qrCodeView" fitWidth="220" fitHeight="220"
                           preserveRatio="true"
                           style="-fx-border-color: #1a1a1a; -fx-border-width: 2;"/>

                <!-- Instructions -->
                <Label text="Scannez ce QR code avec Google Authenticator,"
                       style="-fx-text-fill: #636E72;">
                    <font><Font size="12.0"/></font>
                </Label>
                <Label text="Authy ou Microsoft Authenticator."
                       style="-fx-text-fill: #636E72;">
                    <font><Font size="12.0"/></font>
                </Label>

                <!-- Cle manuelle -->
                <VBox alignment="CENTER" spacing="4">
                    <Label text="Ou entrez cette cle manuellement :"
                           style="-fx-text-fill: #636E72; -fx-font-size: 11;"/>
                    <Label fx:id="secretLabel" text=""
                           style="-fx-text-fill: #1a1a1a;
                                  -fx-font-family: monospace;
                                  -fx-font-size: 13;
                                  -fx-font-weight: bold;
                                  -fx-background-color: #F8F9FA;
                                  -fx-border-color: #dee2e6;
                                  -fx-border-width: 1;
                                  -fx-border-radius: 6;
                                  -fx-background-radius: 6;
                                  -fx-padding: 6 12 6 12;">
                    </Label>
                </VBox>

                <!-- Champ de confirmation -->
                <VBox spacing="5.0">
                    <Label text="Code de confirmation (6 chiffres)"
                           style="-fx-text-fill: #1a1a1a; -fx-font-weight: bold;">
                        <font><Font size="12.0"/></font>
                    </Label>
                    <TextField fx:id="confirmCodeField" promptText="123456"
                               prefWidth="280" prefHeight="40"
                               style="-fx-font-size: 18; -fx-alignment: center; -fx-font-weight: bold;"/>
                </VBox>

                <!-- Erreur / Statut -->
                <Label fx:id="errorLabel" text=""
                       style="-fx-text-fill: white;
                              -fx-background-color: #FF7675;
                              -fx-background-radius: 8;
                              -fx-border-color: #1a1a1a;
                              -fx-border-width: 2;
                              -fx-border-radius: 8;
                              -fx-padding: 6 12 6 12;
                              -fx-font-weight: bold;"
                       visible="false" managed="false" wrapText="true" maxWidth="320">
                    <font><Font size="11.0"/></font>
                </Label>

                <Label fx:id="statusLabel" text=""
                       style="-fx-text-fill: white;
                              -fx-background-color: #00B894;
                              -fx-background-radius: 8;
                              -fx-border-color: #1a1a1a;
                              -fx-border-width: 2;
                              -fx-border-radius: 8;
                              -fx-padding: 6 12 6 12;
                              -fx-font-weight: bold;"
                       visible="false" managed="false">
                    <font><Font size="11.0"/></font>
                </Label>

                <!-- Boutons -->
                <Button fx:id="btnEnable" text="Activer le 2FA" onAction="#handleEnable"
                        prefWidth="280" prefHeight="44"
                        style="-fx-background-color: #00B894;
                               -fx-text-fill: white;
                               -fx-font-size: 14;
                               -fx-font-weight: bold;
                               -fx-background-radius: 12;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 3;
                               -fx-border-radius: 12;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, #1a1a1a, 0, 0, 4, 4);">
                </Button>

                <Button fx:id="btnDisable" text="Desactiver le 2FA" onAction="#handleDisable"
                        prefWidth="280" prefHeight="44"
                        style="-fx-background-color: #FF7675;
                               -fx-text-fill: white;
                               -fx-font-size: 14;
                               -fx-font-weight: bold;
                               -fx-background-radius: 12;
                               -fx-border-color: #1a1a1a;
                               -fx-border-width: 3;
                               -fx-border-radius: 12;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(three_pass_box, #1a1a1a, 0, 0, 4, 4);">
                </Button>

            </VBox>
        </VBox>
    </center>

</BorderPane>
